# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/simengine
DB_POOL_SIZE=10

# Redis
REDIS_URL=redis://localhost:6379/0

# Worker
WORKER_HEARTBEAT_INTERVAL_SECONDS=5
WORKER_LEASE_TIMEOUT_SECONDS=30
WORKER_MAX_CONCURRENT_JOBS=1

# Reaper
REAPER_INTERVAL_SECONDS=30

# Retry
DEFAULT_MAX_RETRIES=3
DEFAULT_BASE_BACKOFF_SECONDS=5.0
DEFAULT_MAX_BACKOFF_SECONDS=300.0

# Priority
AGING_THRESHOLD_SECONDS=300
BACKPRESSURE_QUEUE_DEPTH_LIMIT=10000

# Circuit Breaker
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_WINDOW_SECONDS=300
CIRCUIT_BREAKER_COOLDOWN_SECONDS=600

# LLM
ANTHROPIC_API_KEY=your-key-here
LLM_MODEL=claude-sonnet-4-20250514

# DAG
MAX_DAG_NODES=50

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
